<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="GalliumWinUI.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:GalliumWinUI"
    Title="Gallium">

    <Grid RowDefinitions="Auto,*,Auto" Margin="12">

        <!-- Status bar -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,8" Spacing="8">
            <TextBlock x:Name="ModelLabel" VerticalAlignment="Center"
                       FontWeight="SemiBold" FontSize="14"/>
            <TextBlock x:Name="StatusLabel" VerticalAlignment="Center"
                       Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}"
                       FontSize="12"/>
        </StackPanel>

        <!-- Message history -->
        <ScrollViewer Grid.Row="1" x:Name="HistoryScroller"
                      VerticalScrollBarVisibility="Auto">
            <ItemsControl x:Name="MessageList">
                <ItemsControl.ItemTemplate>
                    <DataTemplate x:DataType="local:ChatMessage">
                        <Border Margin="0,3" Padding="10,6" CornerRadius="8"
                                HorizontalAlignment="{x:Bind Alignment}">
                            <Border.Background>
                                <SolidColorBrush Color="{x:Bind BubbleColor}"/>
                            </Border.Background>
                            <TextBlock Text="{x:Bind Text}" TextWrapping="Wrap"
                                       IsTextSelectionEnabled="True" MaxWidth="520"/>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <!-- Input row -->
        <Grid Grid.Row="2" ColumnDefinitions="*,Auto,Auto,Auto"
              Margin="0,8,0,0" ColumnSpacing="6">
            <TextBox x:Name="InputBox" Grid.Column="0"
                     PlaceholderText="Type a message…"
                     KeyDown="InputBox_KeyDown"/>
            <Button x:Name="SendButton" Grid.Column="1" Content="Send"
                    Click="SendButton_Click" IsEnabled="False"/>
            <ToggleButton x:Name="TtsToggle" Grid.Column="2"
                          ToolTipService.ToolTip="Text-to-speech">
                <FontIcon Glyph="&#xE767;"/>
            </ToggleButton>
            <Button x:Name="MicButton" Grid.Column="3"
                    ToolTipService.ToolTip="Voice input (push-to-talk)"
                    Click="MicButton_Click">
                <FontIcon Glyph="&#xE720;"/>
            </Button>
        </Grid>

    </Grid>
</Window>
