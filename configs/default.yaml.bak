llm:
  baseURL: "https://api.openai.com/v1"
  model: "gpt-4o-mini"
  # apiKey: "sk-..."   # or set OPENAI_API_KEY environment variable
  temperature: 0.7
  maxTokens: 512
  contextWindow: 32000

tts:
  enabled: false

stt:
  enabled: false
  locale: "en-US"

