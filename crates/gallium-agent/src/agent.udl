namespace gallium_agent {
    [Throws=AgentError]
    Agent agent_new(CloudAgentConfig config);
};

[Error]
enum AgentError {
    "NetworkError",
    "ParseError",
    "ConfigError",
    "InternalError",
};

dictionary McpServerConfig {
    string command;
    sequence<string> args;
};

/// Configuration for creating a cloud-backed (OpenAI) agent via UniFFI.
dictionary CloudAgentConfig {
    string? base_url;
    string model;
    string? api_key;
    f32? temperature;
    u32 max_tokens;
    u32 context_window;
    string? working_dir;
    string? reasoning_effort;
    string? system_prompt;
    sequence<McpServerConfig> mcp_servers;
};

dictionary AgentResponse {
    string content;
    string? reasoning;
    u64 input_tokens;
    u64 output_tokens;
    u64 total_tokens;
    f32 context_percent;
};

interface Agent {
    [Throws=AgentError]
    AgentResponse step(string user_input);

    void reset();

    void set_system_prompt(string prompt);

    void add_skill(string name, string description, string prompt);

    [Throws=AgentError]
    AgentResponse step_with_allowed_tools(string user_input, sequence<string> allowed_tools);

    string get_conversation_history();
};
